{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=issue-tracker.db"
  },
  "Jwt": {
    "Issuer": "IssueTracker",
    "Audience": "IssueTracker.Frontend",
    "SigningKey": "development-signing-key-change-before-production",
    "ExpirationMinutes": 480
  },
  "TriageAI": {
    "BaseUrl": "http://localhost:1234",
    "Model": "local-model",
    "TimeoutSeconds": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
